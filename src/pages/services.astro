---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    id: 'research',
    title: '0-day Research',
    what: 'Discover and validate high-confidence undisclosed vulnerabilities with reproducible evidence.',
    items: [
      'Vulnerability discovery under defined scope',
      'Reproducible validation steps and impact notes',
      'Remediation guidance and retest support',
    ],
  },
  {
    id: 'framework',
    title: 'Security Framework',
    what: 'Design and build practical security frameworks, playbooks, and tooling aligned to your platform.',
    items: [
      'Security baseline and control mapping',
      'Assessment and automation tooling',
      'Handover documentation for internal teams',
    ],
  },
];
---

<BaseLayout
  title="Services"
  description="Security Framework and 0-day Research services."
  canonicalPath="/services"
>
  <section class="max-w-4xl">
    <h1 class="font-display text-4xl font-bold">Services</h1>
    <p class="mt-4 text-base leading-7 text-text-soft">
      We provide only two focused services: Security Framework and 0-day Research.
    </p>
  </section>

  <section class="mt-10 space-y-6">
    {services.map((service) => (
      <article id={service.id} class="card p-6 md:p-8">
        <h2 class="font-display text-3xl font-semibold">{service.title}</h2>
        <p class="mt-3 text-sm leading-7 text-text-soft">{service.what}</p>
        <ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-text-soft">
          {service.items.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    ))}
  </section>
</BaseLayout>
