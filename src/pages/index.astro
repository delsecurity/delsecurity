---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { SERVICE_CARDS, withBase } from '../config/site';
---

<BaseLayout
  title=""
  description="Security Framework development and 0-day research for trusted partnerships."
  canonicalPath="/"
>
  <section class="grid gap-8 rounded-3xl border border-line bg-surface p-8 md:grid-cols-[1.3fr_1fr] md:p-12">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-brand">Del Security</p>
      <h1 class="mt-4 font-display text-4xl leading-tight font-bold text-text md:text-5xl">
        0-day Research and Security Framework.
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-7 text-text-soft">
        Focused technical services with concise intake, clear execution, and practical outcomes.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="rounded-full bg-brand px-5 py-2.5 text-sm font-semibold text-white" href={withBase('/services')}>Our Services</a>
        <a class="rounded-full border border-line px-5 py-2.5 text-sm font-semibold text-text" href={withBase('/contact')}>Get in touch</a>
      </div>
    </div>
    <div class="grid content-start gap-3">
      <span class="inline-flex w-fit rounded-full bg-brand-soft px-3 py-1 text-xs font-medium text-brand">Focused</span>
      <span class="inline-flex w-fit rounded-full bg-brand-soft px-3 py-1 text-xs font-medium text-brand">Transparent</span>
      <span class="inline-flex w-fit rounded-full bg-brand-soft px-3 py-1 text-xs font-medium text-brand">Trusted</span>
    </div>
  </section>

  <section class="mt-16">
    <div class="mb-6 flex items-end justify-between gap-4">
      <h2 class="font-display text-3xl font-semibold">Services</h2>
      <a class="text-sm font-semibold text-brand" href={withBase('/services')}>View services</a>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {SERVICE_CARDS.map((service) => <ServiceCard name={service.name} summary={service.summary} />)}
    </div>
  </section>

  <section class="mt-16 card p-6">
    <h2 class="font-display text-3xl font-semibold">Contact</h2>
    <p class="mt-4 text-sm leading-7 text-text-soft">
      If you need to start an engagement, contact us directly via the details in the Contact page.
    </p>
    <a class="mt-5 inline-flex text-sm font-semibold text-brand" href={withBase('/contact')}>Go to Contact</a>
  </section>
</BaseLayout>
